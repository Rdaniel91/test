// --- Helpers ---------------------------------------------------------------------------------
const clamp = (n, min, max) => Math.max(min, Math.min(max, n));
const fmt = (n) => new Intl.NumberFormat("fr-FR", { style: "currency", currency: "EUR" }).format(n);

// Calcule le périmètre (pour surface des murs) en retirant l'ouverture de porte (optionnel)
function computeSurfaces({ length, width, height, doorWidth = 0.9, doorHeight = 2.05 }) {
  const areaFloor = length * width; // m²
  const perimeter = 2 * (length + width);
  const maxDoorWidth = Math.max(length, width);
  const safeDoorWidth = Math.max(0, Math.min(maxDoorWidth, Number.isFinite(doorWidth) ? doorWidth : 0));
  const safeDoorHeight = Math.max(0, Math.min(height, Number.isFinite(doorHeight) ? doorHeight : 0));
  const rawDoorArea = safeDoorWidth > 0 && safeDoorHeight > 0 ? safeDoorWidth * safeDoorHeight : 0;
  const maxDoorArea = perimeter * height;
  const doorArea = Math.min(rawDoorArea, maxDoorArea);
  const wallArea = Math.max(0, perimeter * height - doorArea); // m², simplifié
  return { areaFloor, wallArea, doorArea, door: { width: safeDoorWidth, height: safeDoorHeight } };
}

function download(filename, content) {
  const blob = new Blob([content], { type: "application/json;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
}

async function fileToDataUrl(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

// --- PDF table rendering --------------------------------------------------------------------
const DEFAULT_MARGIN = 40;

/**
 * Rend un tableau dans jsPDF, avec compatibilité large:
 * - utilise autoTable(doc, options) si import dispo (v3)
 * - sinon utilise doc.autoTable(...) si plugin patch l'instance
 * - sinon, fallback manuel (dessin de cellules + sauts de page + wrap texte)
 * Retourne la coordonnée Y finale.
 */
function renderTable(doc, { startY, headers, rows, widths, alignRightCols = [2, 4, 5], margin = DEFAULT_MARGIN }) {
  const pageWidth = doc.internal.pageSize.getWidth();
  const pageHeight = doc.internal.pageSize.getHeight();
  const tableWidth = pageWidth - margin * 2;
  const safeWidths = Array.isArray(widths) && widths.length === headers.length
    ? widths
    : [0.34, 0.16, 0.08, 0.08, 0.17, 0.17].map((f) => f * tableWidth);

  // 1) jsPDF-Autotable v3 style
  if (typeof autoTable === "function") {
    try {
      autoTable(doc, {
        startY,
        head: [headers],
        body: rows,
        styles: { fontSize: 9, cellPadding: 6 },
        headStyles: { fillColor: [240, 240, 240] },
        columnStyles: {
          2: { halign: "right", cellWidth: safeWidths[2] },
          4: { halign: "right", cellWidth: safeWidths[4] },
          5: { halign: "right", cellWidth: safeWidths[5] },
        },
        theme: "grid",
        tableWidth,
        margin: { left: margin, right: margin },
      });
      // @ts-ignore
      const finalY = (doc.lastAutoTable && doc.lastAutoTable.finalY) || (doc.autoTable && doc.autoTable.previous && doc.autoTable.previous.finalY) || startY;
      return finalY;
    } catch (_) { /* si import incompatible, on continue vers 2) */ }
  }

  // 2) jsPDF-Autotable instance method
  if (typeof doc.autoTable === "function") {
    try {
      // @ts-ignore
      doc.autoTable({
        startY,
        head: [headers],
        body: rows,
        styles: { fontSize: 9, cellPadding: 6 },
        headStyles: { fillColor: [240, 240, 240] },
        columnStyles: {
          2: { halign: "right", cellWidth: safeWidths[2] },
          4: { halign: "right", cellWidth: safeWidths[4] },
          5: { halign: "right", cellWidth: safeWidths[5] },
        },
        theme: "grid",
        tableWidth,
        margin: { left: margin, right: margin },
      });
      // @ts-ignore
      const finalY = (doc.lastAutoTable && doc.lastAutoTable.finalY) || (doc.autoTable && doc.autoTable.previous && doc.autoTable.previous.finalY) || startY;
      return finalY;
    } catch (_) { /* si plugin présent mais casse, fallback manuel */ }
  }

  // 3) Fallback manuel
  const padX = 6;
  const lineHeight = 12;
  let y = startY;

  function drawHeader() {
    let x = margin;
    doc.setFillColor(240);
    const headerHeight = lineHeight + 8;
    headers.forEach((h, i) => {
      doc.rect(x, y, safeWidths[i], headerHeight, "F");
      doc.setFontSize(9);
      doc.text(String(h), x + padX, y + headerHeight - 8);
      x += safeWidths[i];
    });
    y += headerHeight;
  }

  function ensurePageSpace(minHeight) {
    if (y + minHeight > pageHeight - margin) {
      doc.addPage();
      y = margin;
      drawHeader(); // répéter l'en-tête sur nouvelle page
    }
  }

  // dessiner entête
  drawHeader();

  // dessiner lignes
  rows.forEach((row) => {
    // calcul hauteur en fonction du wrapping
    let x = margin;
    const cellLines = row.map((cell, i) => {
      const text = String(cell);
      const maxWidth = safeWidths[i] - padX * 2;
      return doc.splitTextToSize(text, Math.max(10, maxWidth));
    });
    const maxLines = Math.max(...cellLines.map((ls) => ls.length));
    const rowHeight = maxLines * lineHeight + 8;

    ensurePageSpace(rowHeight);

    row.forEach((cell, i) => {
      const w = safeWidths[i];
      doc.rect(x, y, w, rowHeight);
      const lines = cellLines[i];
      lines.forEach((ln, idx) => {
        const yy = y + 6 + (idx + 1) * lineHeight - 4;
        const isRight = alignRightCols.includes(i);
        if (isRight) {
          doc.text(String(ln), x + w - padX, yy, { align: "right" });
        } else {
          doc.text(String(ln), x + padX, yy);
        }
      });
      x += w;
    });

    y += rowHeight;
  });

  return y;
}

// --- Composants UI ---------------------------------------------------------------------------
function Field({ label, children }) {
  return (
    <label className="flex flex-col gap-1 text-sm">
      <span className="text-gray-700">{label}</span>
      {children}
    </label>
  );
}

function Select({ value, onChange, options }) {
  return (
    <select value={value} onChange={(e) => onChange(e.target.value)} className="border rounded-xl p-2">
      {options.map((o) => (
        <option key={o.value} value={o.value}>
          {o.label}
        </option>
      ))}
    </select>
  );
}

function NumberInput({ value, onChange, min = 0.5, max = 20, step = 0.1 }) {
  return (
    <input
      type="number"
      className="border rounded-xl p-2"
      value={value}
      min={min}
      max={max}
      step={step}
      onChange={(e) => onChange(clamp(Number(e.target.value), min, max))}
    />
  );
}

function Section({ title, children, right }) {
  return (
    <div className="bg-white rounded-2xl shadow p-4 md:p-6">
      <div className="flex items-center justify-between mb-3">
        <h3 className="text-lg font-semibold">{title}</h3>
        {right}
      </div>
      {children}
    </div>
  );
}

function PreviewRoom({ floor, wall, length, width }) {
  // Représentation 2D simple du sol avec pattern/texture
  const cols = 12; // grille d'aperçu
  const rows = Math.round((width / length) * cols) || 1;
  const cells = Array.from({ length: rows * cols });

  const tileStyle = () => {
    const cfg = floor?.preview;
    const base = cfg?.baseColor || "#e5e7eb";
    const joint = cfg?.jointColor || "#d1d5db";
    const type = cfg?.type || "solid";

    const src = (cfg && (cfg.textureDataUrl || cfg.textureUrlRaw)) || "";
    if (type === "texture" && src) {
      const safeUrl = src.startsWith("data:") ? src : encodeURI(src);
      const size = cfg.repeatSizePx || 60;
      return {
        backgroundImage: `url(${safeUrl})`,
        backgroundRepeat: "repeat",
        backgroundSize: `${size}px ${size}px`,
        backgroundPosition: "center",
        border: `1px solid ${joint}`,
      } as React.CSSProperties;
    }

    const tile = {
      backgroundColor: base,
      border: `1px solid ${joint}`,
    } as React.CSSProperties;
    const plank = {
      background: base,
      borderLeft: `1px solid ${joint}`,
    } as React.CSSProperties;
    const solid = {
      background: base,
      border: `1px solid ${joint}`,
    } as React.CSSProperties;

    const styleBy: Record<string, React.CSSProperties> = { tile, plank, solid };
    return styleBy[type] || solid;
  };

  const wallStyle: React.CSSProperties = { background: wall?.preview?.baseColor || "#ffffff" };

  return (
    <div className="flex flex-col gap-2">
      <div className="h-20 rounded-xl" style={wallStyle} />
      <div className="grid rounded-xl overflow-hidden" style={{ gridTemplateColumns: `repeat(${cols}, minmax(0,1fr))` }}>
        {cells.map((_, i) => (
          <div key={i} className="aspect-square" style={tileStyle()} />
        ))}
      </div>
      <div className="text-xs text-gray-500">Aperçu schématique – non contractuel</div>
    </div>
  );
}

