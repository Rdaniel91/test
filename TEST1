  const { areaFloor, wallArea, doorArea, door } = useMemo(
    () =>
      computeSurfaces({
        length,
        width,
        height,
        doorWidth: includeDoor ? doorWidth : 0,
        doorHeight: includeDoor ? doorHeight : 0,
      }),
    [length, width, height, doorWidth, doorHeight, includeDoor]
  );
  const effectiveDoorWidth = door.width;
  const effectiveDoorHeight = door.height;
  const doorSummaryText = includeDoor
    ? `${doorArea.toFixed(2)} m² (${effectiveDoorWidth.toFixed(2)} m × ${effectiveDoorHeight.toFixed(2)} m)`
    : "Aucune";

  // Lignes de devis (matériaux)
  const materialLines = useMemo(() => {
    const lines: { sku: string; label: string; unit: string; qty: number; unitPrice: number }[] = [];

    // Sol
    if (floor) {
      const qty = areaFloor * (1 + (floor.wastage || 0));
      lines.push({ sku: floor.sku, label: floor.label, unit: floor.unit, qty: +qty.toFixed(2), unitPrice: floor.price });
    }

    // Murs
    if (wall) {
      const qty = wallArea * (1 + (wall.wastage || 0));
      lines.push({ sku: wall.sku, label: wall.label, unit: wall.unit, qty: +qty.toFixed(2), unitPrice: wall.price });
    }

    // Meubles
    furnitureSkus.forEach((sku) => {
      const p = CATALOG.meubles.find((x) => x.sku === sku);
      if (p) lines.push({ sku: p.sku, label: p.label, unit: p.unit, qty: 1, unitPrice: p.price });
    });

    return lines;
  }, [areaFloor, wallArea, floor, wall, furnitureSkus]);

  // Lignes de devis (main d'œuvre – règles simples d'exemple)
  const laborLines = useMemo(() => {
    const lines: { sku: string; label: string; unit: string; qty: number; unitPrice: number }[] = [];
    if (floor) {
      const mo = CATALOG.main_oeuvre.find((x) => x.sku === "MO-POSE-CARRELAGE");
      const parquet = CATALOG.main_oeuvre.find((x) => x.sku === "MO-POSE-PARQUET");
      const isParquet = floor.sku.includes("PARQUET");
      const ref = isParquet ? parquet : mo;
      const qty = areaFloor;
      if (ref) lines.push({ sku: ref.sku, label: ref.label, unit: ref.unit, qty: +qty.toFixed(2), unitPrice: ref.price });
    }
    if (wall) {
      const mo = CATALOG.main_oeuvre.find((x) => x.sku === "MO-POSE-CARRELAGE");
      if (wall.sku.includes("FAIENCE") && mo) {
        lines.push({ sku: mo.sku, label: mo.label + " (murs)", unit: mo.unit, qty: +wallArea.toFixed(2), unitPrice: mo.price });
      }
    }
    furnitureSkus.forEach((sku) => {
      const mo = CATALOG.main_oeuvre.find((x) => x.sku === "MO-POSE-SANITAIRE");
      if (mo) lines.push({ sku: mo.sku, label: mo.label, unit: mo.unit, qty: 1, unitPrice: mo.price });
    });
    return lines;
  }, [floor, wall, areaFloor, wallArea, furnitureSkus]);

  const allLines = [...materialLines, ...laborLines];
  const totalHT = allLines.reduce((s, l) => s + l.qty * l.unitPrice, 0);
  const tvaRate = 0.2; // exemple 20%
  const totalTVA = totalHT * tvaRate;
  const totalTTC = totalHT + totalTVA;

  function toggleFurniture(sku: string) {
    setFurnitureSkus((prev) => (prev.includes(sku) ? prev.filter((x) => x !== sku) : [...prev, sku]));
  }

  function exportDevis() {
    const devis = {
      meta: {
        version: 1,
        generatedAt: new Date().toISOString(),
        clientNote: "Devis indicatif basé sur les sélections du configurateur. Sous réserve de métrés et visite technique.",
      },
      entreprise: { name: companyName, details: companyDetails },
      piece: {
        length,
        width,
        height,
        surfaces: {
          sol_m2: +areaFloor.toFixed(2),
          murs_m2: +wallArea.toFixed(2),
          porte_m2: includeDoor ? +doorArea.toFixed(2) : 0,
        },
        ouverture_porte: includeDoor
          ? { largeur_m: +effectiveDoorWidth.toFixed(2), hauteur_m: +effectiveDoorHeight.toFixed(2) }
          : null,
      },
      lignes: allLines.map((l) => ({ ...l, total: +(l.qty * l.unitPrice).toFixed(2) })),
      totaux: { totalHT: +totalHT.toFixed(2), tvaRate, totalTVA: +totalTVA.toFixed(2), totalTTC: +totalTTC.toFixed(2) },
      conditions,
    };
    download(`devis-configurateur-${Date.now()}.json`, JSON.stringify(devis, null, 2));
  }

  function exportPDF() {
    const doc = new jsPDF({ unit: "pt", format: "a4" });
    const margin = DEFAULT_MARGIN;
    const pageWidth = doc.internal.pageSize.getWidth();

    // Header
    if (logoDataUrl) {
      try { doc.addImage(logoDataUrl, "PNG", margin, margin, 120, 60); } catch (e) { /* ignore */ }
    }
    doc.setFontSize(20);
    doc.text("DEVIS", pageWidth - margin, margin + 20, { align: "right" });
    doc.setFontSize(10);
    const lines = doc.splitTextToSize(companyDetails, 220);
    doc.text(companyName, pageWidth - margin, margin + 40, { align: "right" });
    doc.text(lines, pageWidth - margin, margin + 56, { align: "right" });

    // Infos pièce
    doc.setFontSize(12);
    doc.text(`Pièce: L ${length} m × l ${width} m × h ${height} m`, margin, 140);
    const doorText = includeDoor ? ` – porte ${doorArea.toFixed(2)} m²` : "";
    doc.text(`Surfaces: sol ${areaFloor.toFixed(2)} m² – murs ${wallArea.toFixed(2)} m²${doorText}`, margin, 160);

    // Tableau lignes
    const rows = allLines.map((l) => [
      l.label,
      l.sku,
      String(l.qty),
      l.unit,
      (l.unitPrice).toFixed(2) + " €",
      (l.qty * l.unitPrice).toFixed(2) + " €",
    ]);

    const finalY = renderTable(doc, {
      startY: 180,
      headers: ["Désignation", "SKU", "Qté", "Unité", "PU HT", "Total HT"],
      rows,
      widths: undefined, // utilise la répartition par défaut
      alignRightCols: [2, 4, 5],
      margin,
    });

    let y = finalY + 20;
    // Totaux
    doc.setFontSize(12);
    doc.text(`Sous-total HT: ${totalHT.toFixed(2)} €`, pageWidth - margin, y, { align: "right" }); y += 18;
    doc.text(`TVA (20%): ${totalTVA.toFixed(2)} €`, pageWidth - margin, y, { align: "right" }); y += 18;
    doc.setFontSize(14);
    doc.text(`Total TTC: ${totalTTC.toFixed(2)} €`, pageWidth - margin, y, { align: "right" }); y += 28;

    // Conditions
    doc.setFontSize(10);
    doc.text("Conditions", margin, y);
    const condLines = doc.splitTextToSize(conditions, pageWidth - margin * 2);
    doc.text(condLines, margin, y + 16);

    // Footer
    const pageHeight = doc.internal.pageSize.getHeight();
    doc.setFontSize(9);
    doc.text(`Généré le ${new Date().toLocaleDateString('fr-FR')} via Configurateur Cosmos`, pageWidth / 2, pageHeight - 20, { align: "center" });

    doc.save(`devis-${Date.now()}.pdf`);
  }

  // --- Tests (auto) -------------------------------------------------------------------------
  const approxEq = (a: number, b: number, eps = 0.02) => Math.abs(a - b) <= eps;
  const selfTests = useMemo(() => {
    const out: { name: string; passed: boolean; expected: unknown; got: unknown }[] = [];

    // Test 1: computeSurfaces avec dimensions fixes
    const s = computeSurfaces({ length: 3.0, width: 2.4, height: 2.5 });
    out.push({
      name: "Surface sol 3.0×2.4",
      passed: approxEq(s.areaFloor, 7.2, 0.001),
      expected: 7.2,
      got: +s.areaFloor.toFixed(3),
    });
    out.push({
      name: "Surface murs (porte déduite)",
      passed: approxEq(s.wallArea, 25.155, 0.02),
      expected: 25.155,
      got: +s.wallArea.toFixed(3),
    });
    out.push({
      name: "Surface porte par défaut",
      passed: approxEq(s.doorArea, 1.845, 0.02),
      expected: 1.845,
      got: +s.doorArea.toFixed(3),
    });
    out.push({
      name: "Dimensions porte sécurisées",
      passed: approxEq(s.door.width, 0.9, 0.001) && approxEq(s.door.height, 2.05, 0.001),
      expected: "0.90 m × 2.05 m",
      got: `${s.door.width.toFixed(2)} m × ${s.door.height.toFixed(2)} m`,
    });

    const sNoDoor = computeSurfaces({ length: 3.0, width: 2.4, height: 2.5, doorWidth: 0, doorHeight: 0 });
    out.push({
      name: "Surface murs sans porte",
      passed: approxEq(sNoDoor.wallArea, 27.0, 0.02),
      expected: 27.0,
      got: +sNoDoor.wallArea.toFixed(3),
    });
    const sOversizedDoor = computeSurfaces({
      length: 3.0,
      width: 2.4,
      height: 2.5,
      doorWidth: 9,
      doorHeight: 4,
    });
    out.push({
      name: "Porte surdimensionnée limitée",
      passed:
        approxEq(sOversizedDoor.door.width, 3.0, 0.001) &&
        approxEq(sOversizedDoor.door.height, 2.5, 0.001) &&
        approxEq(sOversizedDoor.doorArea, 7.5, 0.02),
      expected: "3.00 m × 2.50 m (7.50 m²)",
      got: `${sOversizedDoor.door.width.toFixed(2)} m × ${sOversizedDoor.door.height.toFixed(2)} m (${sOversizedDoor.doorArea.toFixed(2)} m²)`,
    });

    // Test 2: quantités matériaux avec pertes, arrondies à 2 décimales
    const floorP = CATALOG.sols[0];
    const wallP = CATALOG.murs[0];
    const floorQty = +((7.2) * (1 + (floorP.wastage || 0))).toFixed(2);
    const wallQty = +((25.155) * (1 + (wallP.wastage || 0))).toFixed(2);
    out.push({ name: "Sol qty avec pertes (m²)", passed: floorQty === 7.78, expected: 7.78, got: floorQty });
    out.push({ name: "Murs qty avec pertes (m²)", passed: wallQty === 26.41, expected: 26.41, got: wallQty });

    // Test 3: fonctions export
    out.push({ name: "exportDevis défini", passed: typeof exportDevis === "function", expected: "function", got: typeof exportDevis });
    out.push({ name: "exportPDF défini", passed: typeof exportPDF === "function", expected: "function", got: typeof exportPDF });

    // Test 4: présence librairie PDF
    out.push({ name: "jsPDF dispo", passed: typeof jsPDF === "function", expected: "function", got: typeof jsPDF });

    // Test 5: table renderer dispo et renvoie une Y valide
    try {
      const td = new jsPDF({ unit: "pt", format: "a4" });
      const y = renderTable(td, {
        startY: 100,
        headers: ["A", "B"],
        rows: [["x", "1"], ["yyy", "2"]],
        widths: [200, 100],
        alignRightCols: [1],
        margin: 40,
      });
      out.push({ name: "renderTable finalY numérique", passed: typeof y === "number" && y >= 100, expected: ">= 100", got: String(y) });
    } catch (e: any) {
      out.push({ name: "renderTable exécutable", passed: false, expected: "no error", got: e?.message || String(e) });
    }

    // Test 6: texture Limestone présente
    out.push({
      name: "Texture Limestone définie",
      passed: !!CATALOG.sols.find((p) => p.sku === "SOL-GRES-LIMESTONE-6060-SAND")?.preview?.textureDataUrl,
      expected: true,
      got: !!CATALOG.sols.find((p) => p.sku === "SOL-GRES-LIMESTONE-6060-SAND")?.preview?.textureDataUrl,
    });

    // Test 7: base64 data URL valide
    out.push({
      name: "Texture base64 valide",
      passed: /^data:image\//.test(String(CATALOG.sols.find((p)=>p.sku==="SOL-GRES-LIMESTONE-6060-SAND")?.preview?.textureDataUrl || "")),
      expected: true,
      got: String(CATALOG.sols.find((p)=>p.sku==="SOL-GRES-LIMESTONE-6060-SAND")?.preview?.textureDataUrl || "").slice(0,15)+"…",
    });

    return out;
  }, []);

  return (
    <div className="min-h-screen bg-gray-50 p-4 md:p-8">
      <div className="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div className="lg:col-span-2 flex flex-col gap-6">
          <Section title="Aperçu de la pièce">
            <PreviewRoom floor={floor} wall={wall} length={length} width={width} />
          </Section>

          <Section title="Sélection des matériaux & équipements">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <Field label="Sol">
                <Select
                  value={floorSku}
                  onChange={setFloorSku}
                  options={CATALOG.sols.map((p) => ({ value: p.sku, label: `${p.label} – ${fmt(p.price)}/${p.unit}` }))}
                />
              </Field>
              <Field label="Murs">
                <Select
                  value={wallSku}
                  onChange={setWallSku}
                  options={CATALOG.murs.map((p) => ({ value: p.sku, label: `${p.label} – ${fmt(p.price)}/${p.unit}` }))}
                />
              </Field>
              <Field label="Meubles & sanitaires">
                <div className="flex flex-col gap-2">
                  {CATALOG.meubles.map((p) => (
                    <label key={p.sku} className="flex items-center gap-2">
                      <input type="checkbox" checked={furnitureSkus.includes(p.sku)} onChange={() => toggleFurniture(p.sku)} />
                      <span>
                        {p.preview?.icon} {p.label} – {fmt(p.price)}
                      </span>
                    </label>
                  ))}
                </div>
              </Field>
            </div>
          </Section>
        </div>

        <div className="lg:col-span-1 flex flex-col gap-6">
          <Section
            title="Dimensions"
            right={<span className="text-sm text-gray-500">en mètres</span>}
          >
            <div className="grid grid-cols-2 gap-4">
              <Field label="Longueur">
                <NumberInput value={length} onChange={setLength} />
              </Field>
              <Field label="Largeur">
                <NumberInput value={width} onChange={setWidth} />
              </Field>
              <Field label="Hauteur">
                <NumberInput value={height} onChange={setHeight} />
              </Field>
              <label className="col-span-2 flex items-center gap-2 text-sm text-gray-700">
                <input
                  type="checkbox"
                  checked={includeDoor}
                  onChange={(e) => setIncludeDoor(e.target.checked)}
                />
                <span>Déduire une ouverture de porte</span>
              </label>
              {includeDoor && (
                <>
                  <Field label="Largeur porte (m)">
                    <NumberInput
                      value={doorWidth}
                      onChange={setDoorWidth}
                      min={0}
                      max={Math.max(length, width)}
                      step={0.05}
                    />
                  </Field>
                  <Field label="Hauteur porte (m)">
                    <NumberInput
                      value={doorHeight}
                      onChange={setDoorHeight}
                      min={0}
                      max={height}
                      step={0.05}
                    />
                  </Field>
                </>
              )}
            </div>
            <div className="mt-3 text-sm text-gray-600">
              <div>Surface sol: <strong>{areaFloor.toFixed(2)} m²</strong></div>
              <div>Surface murs (net): <strong>{wallArea.toFixed(2)} m²</strong></div>
              <div>
                Ouverture porte déduite:
                <strong className="ml-1">{doorSummaryText}</strong>
              </div>
            </div>
          </Section>

          <Section title="Devis transparent">
            <div className="max-h-60 overflow-auto divide-y">
              {allLines.map((l, idx) => (
                <div key={idx} className="flex items-center justify-between py-2 text-sm">
                  <div className="flex-1 pr-2">
                    <div className="font-medium">{l.label}</div>
                    <div className="text-gray-500">{l.sku} • {l.qty} {l.unit}</div>
                  </div>
                  <div className="text-right">
                    <div>{fmt(l.unitPrice)} / {l.unit}</div>
                    <div className="font-semibold">{fmt(l.qty * l.unitPrice)}</div>
                  </div>
                </div>
              ))}
            </div>
            <div className="mt-4 border-t pt-3 text-sm">
              <div className="flex justify-between"><span>Sous-total (HT)</span><strong>{fmt(totalHT)}</strong></div>
              <div className="flex justify-between"><span>TVA (20%)</span><strong>{fmt(totalTVA)}</strong></div>
              <div className="flex justify-between text-lg mt-1"><span>Total TTC</span><strong>{fmt(totalTTC)}</strong></div>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-4">
              <button onClick={exportDevis} className="rounded-2xl px-4 py-2 bg-gray-800 text-white hover:opacity-90">
                Exporter le devis (JSON)
              </button>
              <button onClick={exportPDF} className="rounded-2xl px-4 py-2 bg-black text-white hover:opacity-90">
                Télécharger le devis (PDF)
              </button>
            </div>
            <p className="mt-2 text-xs text-gray-500">Le PDF se génère côté navigateur et peut être envoyé à votre ERP/CRM.</p>
          </Section>

          <Section title="Identité & PDF">
            <div className="grid grid-cols-1 gap-3 text-sm">
              <label className="flex flex-col gap-1">
                <span className="text-gray-700">Nom de l'entreprise</span>
                <input className="border rounded-xl p-2" value={companyName} onChange={(e) => setCompanyName(e.target.value)} />
              </label>
              <label className="flex flex-col gap-1">
                <span className="text-gray-700">Coordonnées (adresse, SIREN, contact)</span>
                <textarea className="border rounded-xl p-2" rows={3} value={companyDetails} onChange={(e) => setCompanyDetails(e.target.value)} />
              </label>
              <label className="flex flex-col gap-1">
                <span className="text-gray-700">Logo (PNG/JPG)</span>
                <input
                  type="file"
                  accept="image/*"
                  onChange={async (e) => {
                    const file = e.target.files?.[0];
                    if (file) {
                      const dataUrl = await fileToDataUrl(file);
                      setLogoDataUrl(String(dataUrl));
                    }
                  }}
                />
                <span className="text-xs text-gray-500">Optionnel — s'affichera en haut du PDF.</span>
              </label>
              <label className="flex flex-col gap-1">
                <span className="text-gray-700">Conditions</span>
                <textarea className="border rounded-xl p-2" rows={4} value={conditions} onChange={(e) => setConditions(e.target.value)} />
              </label>
            </div>
          </Section>

          <Section title="Tests (automatiques)">
            <ul className="text-sm space-y-2">
              {selfTests.map((t, i) => (
                <li key={i} className="flex items-start gap-2">
                  <span className={`inline-flex h-5 w-5 items-center justify-center rounded-full text-white text-xs ${t.passed ? 'bg-green-600' : 'bg-red-600'}`}>{t.passed ? '✓' : '✗'}</span>
                  <div>
                    <div className="font-medium">{t.name}</div>
                    <div className="text-gray-500">Attendu: {String(t.expected)} • Obtenu: {String(t.got)}</div>
                  </div>
                </li>
              ))}
            </ul>
          </Section>

          <Section title="Prochaines étapes (technique)">
            <ul className="list-disc pl-5 text-sm text-gray-700 space-y-1">
              <li>Brancher le catalogue à votre base interne (SKU, prix, stocks, unités, visuels, variantes).</li>
              <li>Créer une API <code>/api/devis</code> qui reçoit les lignes et renvoie un PDF signé + ID devis.</li>
              <li>Authentification <em>back-office</em> pour gérer le catalogue et les règles de main d'œuvre.</li>
              <li>Améliorer l'aperçu: Three.js/Babylon.js pour 3D, import de plans, AR (WebXR) en option.</li>
              <li>Tracking analytique des choix pour optimiser l'offre et les bundles.</li>
            </ul>
          </Section>
        </div>
      </div>
    </div>
  );
}
